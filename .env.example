# Anthropic API
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-5

# Budget guard — hard ceilings per pipeline run
MAX_LLM_CALLS=40
MAX_TOKENS_PER_RUN=200000

# Response cache (file-backed under logs/cache/)
CACHE_ENABLED=true

# Test-only — when true, RecordedLlmClient calls the real LLM and
# writes responses to src/test/resources/llm_responses/. Default tests
# use FixtureLlmClient and never need this.
RECORD_MODE=false
